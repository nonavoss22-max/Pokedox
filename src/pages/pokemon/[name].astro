---
export const prerender = false;

const { name } = Astro.params;

const response = await fetch(`https://pokeapi.co/api/v2/pokemon/${name}`);
const pokemon = await response.json();

const types = pokemon.types.map((t: any) => t.type.name);
const stats = pokemon.stats.map((s: any) => ({
  name: s.stat.name,
  value: s.base_stat,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pokemon.name} — Pokédex</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; background: #1a1a2e; color: white; min-height: 100vh; }
      nav { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
      nav a { color: white; text-decoration: none; margin-left: 2rem; opacity: 0.7; }
      nav a:hover { opacity: 1; }
      .logo { font-weight: 700; font-size: 1.25rem; color: #e63946; }
      main { max-width: 700px; margin: 3rem auto; padding: 0 2rem; }
      .back { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; display: inline-block; margin-bottom: 2rem; }
      .back:hover { color: white; }
      .header { display: flex; align-items: center; gap: 2rem; margin-bottom: 2rem; }
      .header img { width: 160px; height: 160px; image-rendering: pixelated; }
      .header h1 { font-size: 2.5rem; font-weight: 800; text-transform: capitalize; }
      .number { opacity: 0.4; font-size: 1rem; margin-bottom: 0.5rem; }
      .types { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
      .type { padding: 0.25rem 0.75rem; border-radius: 100px; font-size: 0.8rem; font-weight: 600; background: rgba(255,255,255,0.15); text-transform: capitalize; }
      .section { margin-top: 2rem; }
      .section h2 { font-size: 1rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
      .stat { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
      .stat-name { width: 140px; font-size: 0.85rem; opacity: 0.6; text-transform: capitalize; }
      .stat-bar { flex: 1; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
      .stat-fill { height: 100%; background: #e63946; border-radius: 3px; }
      .stat-value { width: 32px; text-align: right; font-size: 0.85rem; opacity: 0.8; }
    </style>
  </head>
  <body>
    <nav>
      <span class="logo">Pokédex</span>
      <div>
        <a href="/">Home</a>
        <a href="/pokedex">Pokédex</a>
      </div>
    </nav>
    <main>
      <a href="/pokedex" class="back">← Back to Pokédex</a>
      <div class="header">
        <img src={pokemon.sprites.other["official-artwork"].front_default || pokemon.sprites.front_default} alt={pokemon.name} />
        <div>
          <div class="number">#{String(pokemon.id).padStart(3, '0')}</div>
          <h1>{pokemon.name}</h1>
          <div class="types">
            {types.map((t: string) => <span class="type">{t}</span>)}
          </div>
        </div>
      </div>
      <div class="section">
        <h2>Base Stats</h2>
        {stats.map((s: any) => (
          <div class="stat">
            <span class="stat-name">{s.name}</span>
            <div class="stat-bar">
              <div class="stat-fill" style={`width: ${Math.min(s.value / 255 * 100, 100)}%`}></div>
            </div>
            <span class="stat-value">{s.value}</span>
          </div>
        ))}
      </div>
    </main>
  </body>
</html>