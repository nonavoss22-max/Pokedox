---
// Landing page for the Pokédex application
// No data fetching needed here — purely static
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pokédex</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      body {
        font-family: system-ui, sans-serif;
        background: #1a1a2e;
        color: white;
        min-height: 100vh;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }

      nav a {
        color: white;
        text-decoration: none;
        margin-left: 2rem;
        opacity: 0.7;
        transition: opacity 0.2s;
      }

      nav a:hover { opacity: 1; }

      .logo {
        font-weight: 700;
        font-size: 1.25rem;
        color: #e63946;
      }

      hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 6rem 2rem;
        gap: 1.5rem;
      }

      h1 {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
      }

      h1 span { color: #e63946; }

      p {
        font-size: 1.25rem;
        opacity: 0.6;
        max-width: 480px;
      }

      .btn {
        background: #e63946;
        color: white;
        padding: 0.875rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 1rem;
        transition: background 0.2s;
      }

      .btn:hover { background: #c1121f; }
    </style>
  </head>
  <body>
    <nav>
      <span class="logo">Pokédex</span>
      <div>
        <a href="/">Home</a>
        <a href="/pokedex">Pokédex</a>
      </div>
    </nav>

    <hero>
      <h1>Explore the<br /><span>Pokémon</span> World</h1>
      <p>Browse the complete Pokédex, discover stats, abilities, and types for every Pokémon.</p>
      <a href="/pokedex" class="btn">Open Pokédex</a>
    </hero>
  </body>
</html>