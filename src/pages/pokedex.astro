---
// Fetch the first 20 Pokémon from PokéAPI at build time
const response = await fetch("https://pokeapi.co/api/v2/pokemon?limit=20&offset=0");
const data = await response.json();

// For each Pokémon, fetch its details to get the sprite image
const pokemon = await Promise.all(
  data.results.map(async (p: { name: string; url: string }) => {
    const res = await fetch(p.url);
    return res.json();
  })
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pokédex</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: system-ui, sans-serif;
        background: #1a1a2e;
        color: white;
        min-height: 100vh;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }

      nav a {
        color: white;
        text-decoration: none;
        margin-left: 2rem;
        opacity: 0.7;
      }

      nav a:hover { opacity: 1; }
      .logo { font-weight: 700; font-size: 1.25rem; color: #e63946; }

      main {
        padding: 3rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
      }

      h1 { font-size: 2rem; margin-bottom: 2rem; }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }

      .card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 1.5rem 1rem;
        text-align: center;
        text-decoration: none;
        color: white;
        transition: background 0.2s, transform 0.2s;
      }

      .card:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-4px);
      }

      .card img { width: 96px; height: 96px; }

      .card .number {
        font-size: 0.75rem;
        opacity: 0.4;
        margin-bottom: 0.25rem;
      }

      .card .name {
        font-weight: 600;
        text-transform: capitalize;
      }
    </style>
  </head>
  <body>
    <nav>
      <span class="logo">Pokédex</span>
      <div>
        <a href="/">Home</a>
        <a href="/pokedex">Pokédex</a>
      </div>
    </nav>

    <main>
      <h1>Pokédex</h1>
      <div class="grid">
        {pokemon.map((p) => (
          <a href={`/pokemon/${p.name}`} class="card">
            <img src={p.sprites.front_default} alt={p.name} />
            <div class="number">#{String(p.id).padStart(3, '0')}</div>
            <div class="name">{p.name}</div>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>