---
export const prerender = false;

const page = Number(Astro.url.searchParams.get("page") || 1);
const limit = 20;
const offset = (page - 1) * limit;

const response = await fetch(`https://pokeapi.co/api/v2/pokemon?limit=${limit}&offset=${offset}`);
const data = await response.json();
const totalPages = Math.ceil(data.count / limit);

const pokemon = await Promise.all(
  data.results.map(async (p: { name: string; url: string }) => {
    const res = await fetch(p.url);
    return res.json();
  })
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pokédex</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Nunito', sans-serif; background: #0a0a0f; color: #f0f0f5; min-height: 100vh; overflow-x: hidden; }

      body::before {
        content: ''; position: fixed; border-radius: 50%;
        filter: blur(140px); pointer-events: none; z-index: 0;
        width: 700px; height: 700px;
        background: radial-gradient(circle, rgba(249,115,22,0.1) 0%, transparent 70%);
        top: -300px; right: -200px;
      }

      nav {
        position: relative; z-index: 10;
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 2rem;
        background: rgba(10,10,15,0.8); backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      nav a { color: rgba(255,255,255,0.5); text-decoration: none; margin-left: 2rem; transition: color 0.2s; font-weight: 600; font-size: 0.9rem; }
      nav a:hover { color: #f97316; }
      .logo { font-weight: 800; font-size: 1.25rem; color: #f97316; letter-spacing: -0.02em; }

      main { position: relative; z-index: 1; padding: 3rem 2rem; max-width: 1200px; margin: 0 auto; }

      .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
      h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.03em; }
      .page-info { font-size: 0.85rem; color: rgba(255,255,255,0.3); font-weight: 600; }

      .search-bar { display: flex; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap; align-items: center; }
      .search-input {
        flex: 1; min-width: 200px; padding: 0.7rem 1rem;
        border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
        font-family: 'Nunito', sans-serif; font-size: 0.95rem;
        background: rgba(255,255,255,0.05); color: #f0f0f5;
        outline: none; transition: border-color 0.2s;
      }
      .search-input::placeholder { color: rgba(255,255,255,0.2); }
      .search-input:focus { border-color: rgba(249,115,22,0.4); background: rgba(255,255,255,0.07); }

      .type-select {
        padding: 0.7rem 1rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
        font-family: 'Nunito', sans-serif; font-size: 0.95rem;
        background: rgba(255,255,255,0.05); color: #f0f0f5;
        cursor: pointer; outline: none; transition: border-color 0.2s;
      }
      .type-select option { background: #1a1a2e; }
      .type-select:focus { border-color: rgba(249,115,22,0.4); }

      .search-count { font-size: 0.85rem; color: rgba(255,255,255,0.3); font-weight: 600; white-space: nowrap; }

      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 0.85rem; }

      .card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
        border-radius: 16px; padding: 1.25rem 1rem; text-align: center;
        text-decoration: none; color: #f0f0f5;
        transition: border-color 0.2s, transform 0.2s, background 0.2s;
        backdrop-filter: blur(10px);
      }
      .card:hover {
        border-color: rgba(249,115,22,0.35); transform: translateY(-4px);
        background: rgba(249,115,22,0.06);
      }
      .card img { width: 88px; height: 88px; image-rendering: pixelated; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5)); }
      .card .number { font-size: 0.7rem; color: rgba(255,255,255,0.25); margin-bottom: 0.25rem; font-weight: 700; letter-spacing: 0.04em; }
      .card .name { font-weight: 700; text-transform: capitalize; font-size: 0.9rem; }

      .pagination { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 3rem; }
      .btn {
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.7); padding: 0.65rem 1.5rem; border-radius: 10px;
        text-decoration: none; font-weight: 700; font-size: 0.9rem; transition: all 0.15s;
      }
      .btn:hover { background: rgba(249,115,22,0.15); border-color: rgba(249,115,22,0.3); color: #f97316; }
      .btn.disabled { opacity: 0.25; pointer-events: none; }
      .page-count { font-size: 0.85rem; color: rgba(255,255,255,0.3); font-weight: 600; }
    </style>
  </head>
  <body>
    <nav>
      <span class="logo">Pokédex</span>
      <div>
        <a href="/">Home</a>
        <a href="/pokedex">Pokédex</a>
        <a href="/ai-generator">AI Generator</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <main>
      <div class="top-bar">
        <h1>Pokédex</h1>
        <span class="page-info">Page {page} of {totalPages}</span>
      </div>
      <div class="search-bar">
        <input type="text" id="search-input" class="search-input" placeholder="Search Pokémon..." autocomplete="off" />
        <select id="type-filter" class="type-select">
          <option value="">All Types</option>
          <option value="normal">Normal</option>
          <option value="fire">Fire</option>
          <option value="water">Water</option>
          <option value="electric">Electric</option>
          <option value="grass">Grass</option>
          <option value="ice">Ice</option>
          <option value="fighting">Fighting</option>
          <option value="poison">Poison</option>
          <option value="ground">Ground</option>
          <option value="flying">Flying</option>
          <option value="psychic">Psychic</option>
          <option value="bug">Bug</option>
          <option value="rock">Rock</option>
          <option value="ghost">Ghost</option>
          <option value="dragon">Dragon</option>
          <option value="dark">Dark</option>
          <option value="steel">Steel</option>
          <option value="fairy">Fairy</option>
        </select>
        <span id="search-count" class="search-count"></span>
      </div>
      <div id="search-results" class="grid" style="display:none"></div>
      <div class="grid">
        {pokemon.map((p) => (
          <a href={`/pokemon/${p.name}`} class="card">
            <img src={p.sprites.front_default} alt={p.name} />
            <div class="number">#{String(p.id).padStart(3, '0')}</div>
            <div class="name">{p.name}</div>
          </a>
        ))}
      </div>
      <div class="pagination">
        <a href={`/pokedex?page=${page - 1}`} class={`btn ${page <= 1 ? 'disabled' : ''}`}>← Prev</a>
        <span class="page-count">Page {page} of {totalPages}</span>
        <a href={`/pokedex?page=${page + 1}`} class={`btn ${page >= totalPages ? 'disabled' : ''}`}>Next →</a>
      </div>
    </main>
    <script>
      (function () {
        const searchInput = document.getElementById('search-input');
        const typeFilter = document.getElementById('type-filter');
        const searchResults = document.getElementById('search-results');
        const searchCount = document.getElementById('search-count');
        const mainGrid = document.querySelector('.grid:not(#search-results)');
        const pagination = document.querySelector('.pagination');
        const pageInfo = document.querySelector('.page-info');

        let allPokemon = [];
        const typeCache = {};

        fetch('https://pokeapi.co/api/v2/pokemon?limit=1302')
          .then(r => r.json())
          .then(data => {
            allPokemon = data.results.map(p => ({
              name: p.name,
              id: parseInt(p.url.split('/').filter(Boolean).pop())
            }));
          });

        async function getTypeSet(typeName) {
          if (typeCache[typeName]) return typeCache[typeName];
          const res = await fetch(`https://pokeapi.co/api/v2/type/${typeName}`);
          const data = await res.json();
          typeCache[typeName] = new Set(data.pokemon.map(p => p.pokemon.name));
          return typeCache[typeName];
        }

        async function update() {
          const query = searchInput.value.trim().toLowerCase();
          const type = typeFilter.value;

          if (!query && !type) {
            searchResults.style.display = 'none';
            mainGrid.style.display = 'grid';
            pagination.style.display = 'flex';
            pageInfo.style.display = '';
            searchCount.textContent = '';
            return;
          }

          mainGrid.style.display = 'none';
          pagination.style.display = 'none';
          pageInfo.style.display = 'none';

          let filtered = allPokemon;
          if (query) filtered = filtered.filter(p => p.name.includes(query));
          if (type) {
            const typeSet = await getTypeSet(type);
            filtered = filtered.filter(p => typeSet.has(p.name));
          }

          const display = filtered.slice(0, 20);
          searchCount.textContent = filtered.length + ' result' + (filtered.length !== 1 ? 's' : '');
          searchResults.style.display = display.length ? 'grid' : 'none';
          searchResults.innerHTML = display.map(p =>
            `<a href="/pokemon/${p.name}" class="card">` +
            `<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${p.id}.png" ` +
            `alt="${p.name}" loading="lazy" width="88" height="88" />` +
            `<div class="number">#${String(p.id).padStart(3, '0')}</div>` +
            `<div class="name">${p.name}</div></a>`
          ).join('');
        }

        searchInput.addEventListener('input', update);
        typeFilter.addEventListener('change', update);
      })();
    </script>
  </body>
</html>
