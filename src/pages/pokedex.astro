---
export const prerender = false;

const page = Number(Astro.url.searchParams.get("page") || 1);
const limit = 20;
const offset = (page - 1) * limit;

const response = await fetch(`https://pokeapi.co/api/v2/pokemon?limit=${limit}&offset=${offset}`);
const data = await response.json();
const totalPages = Math.ceil(data.count / limit);

const pokemon = await Promise.all(
  data.results.map(async (p: { name: string; url: string }) => {
    const res = await fetch(p.url);
    return res.json();
  })
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pokédex</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Nunito', sans-serif; background: #ffffff; color: #1a1a1a; min-height: 100vh; }
      nav { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 2rem; border-bottom: 1px solid rgba(0,0,0,0.08); }
      nav a { color: #1a1a1a; text-decoration: none; margin-left: 2rem; opacity: 0.6; font-weight: 600; }
      nav a:hover { opacity: 1; }
      .logo { font-weight: 800; font-size: 1.25rem; color: #f97316; }
      main { padding: 3rem 2rem; max-width: 1200px; margin: 0 auto; }
      .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
      h1 { font-size: 2rem; font-weight: 800; }
      .page-info { opacity: 0.4; font-size: 0.9rem; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }
      .card { background: #fff7ed; border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 1.5rem 1rem; text-align: center; text-decoration: none; color: #1a1a1a; transition: box-shadow 0.2s, transform 0.2s; }
      .card:hover { box-shadow: 0 8px 24px rgba(249,115,22,0.15); transform: translateY(-4px); }
      .card img { width: 96px; height: 96px; }
      .card .number { font-size: 0.75rem; opacity: 0.4; margin-bottom: 0.25rem; font-weight: 600; }
      .card .name { font-weight: 700; text-transform: capitalize; }
      .pagination { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 3rem; }
      .btn { background: #f97316; color: white; padding: 0.6rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 700; transition: background 0.2s; }
      .btn:hover { background: #ea6c00; }
      .btn.disabled { opacity: 0.3; pointer-events: none; }
      .page-count { opacity: 0.4; font-size: 0.9rem; }
      .search-bar { display: flex; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap; align-items: center; }
      .search-input { flex: 1; min-width: 200px; padding: 0.65rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 8px; font-family: 'Nunito', sans-serif; font-size: 1rem; outline: none; }
      .search-input:focus { border-color: #f97316; }
      .type-select { padding: 0.65rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 8px; font-family: 'Nunito', sans-serif; font-size: 1rem; background: white; cursor: pointer; outline: none; }
      .type-select:focus { border-color: #f97316; }
      .search-count { opacity: 0.4; font-size: 0.9rem; white-space: nowrap; }
    </style>
  </head>
  <body>
    <nav>
      <span class="logo">Pokédex</span>
      <div>
        <a href="/">Home</a>
        <a href="/pokedex">Pokédex</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <main>
      <div class="header">
        <h1>Pokédex</h1>
        <span class="page-info">Page {page} of {totalPages}</span>
      </div>
      <div class="search-bar">
        <input type="text" id="search-input" class="search-input" placeholder="Search Pokémon..." autocomplete="off" />
        <select id="type-filter" class="type-select">
          <option value="">All Types</option>
          <option value="normal">Normal</option>
          <option value="fire">Fire</option>
          <option value="water">Water</option>
          <option value="electric">Electric</option>
          <option value="grass">Grass</option>
          <option value="ice">Ice</option>
          <option value="fighting">Fighting</option>
          <option value="poison">Poison</option>
          <option value="ground">Ground</option>
          <option value="flying">Flying</option>
          <option value="psychic">Psychic</option>
          <option value="bug">Bug</option>
          <option value="rock">Rock</option>
          <option value="ghost">Ghost</option>
          <option value="dragon">Dragon</option>
          <option value="dark">Dark</option>
          <option value="steel">Steel</option>
          <option value="fairy">Fairy</option>
        </select>
        <span id="search-count" class="search-count"></span>
      </div>
      <div id="search-results" class="grid" style="display:none"></div>
      <div class="grid">
        {pokemon.map((p) => (
          <a href={`/pokemon/${p.name}`} class="card">
            <img src={p.sprites.front_default} alt={p.name} />
            <div class="number">#{String(p.id).padStart(3, '0')}</div>
            <div class="name">{p.name}</div>
          </a>
        ))}
      </div>
      <div class="pagination">
        <a href={`/pokedex?page=${page - 1}`} class={`btn ${page <= 1 ? 'disabled' : ''}`}>← Prev</a>
        <span class="page-count">Page {page} of {totalPages}</span>
        <a href={`/pokedex?page=${page + 1}`} class={`btn ${page >= totalPages ? 'disabled' : ''}`}>Next →</a>
      </div>
    </main>
    <script>
      (function () {
        const searchInput = document.getElementById('search-input');
        const typeFilter = document.getElementById('type-filter');
        const searchResults = document.getElementById('search-results');
        const searchCount = document.getElementById('search-count');
        const mainGrid = document.querySelector('.grid:not(#search-results)');
        const pagination = document.querySelector('.pagination');
        const pageInfo = document.querySelector('.page-info');

        let allPokemon = [];
        const typeCache = {};

        fetch('https://pokeapi.co/api/v2/pokemon?limit=1302')
          .then(r => r.json())
          .then(data => {
            allPokemon = data.results.map(p => ({
              name: p.name,
              id: parseInt(p.url.split('/').filter(Boolean).pop())
            }));
          });

        async function getTypeSet(typeName) {
          if (typeCache[typeName]) return typeCache[typeName];
          const res = await fetch(`https://pokeapi.co/api/v2/type/${typeName}`);
          const data = await res.json();
          typeCache[typeName] = new Set(data.pokemon.map(p => p.pokemon.name));
          return typeCache[typeName];
        }

        async function update() {
          const query = searchInput.value.trim().toLowerCase();
          const type = typeFilter.value;

          if (!query && !type) {
            searchResults.style.display = 'none';
            mainGrid.style.display = 'grid';
            pagination.style.display = 'flex';
            pageInfo.style.display = '';
            searchCount.textContent = '';
            return;
          }

          mainGrid.style.display = 'none';
          pagination.style.display = 'none';
          pageInfo.style.display = 'none';

          let filtered = allPokemon;
          if (query) filtered = filtered.filter(p => p.name.includes(query));
          if (type) {
            const typeSet = await getTypeSet(type);
            filtered = filtered.filter(p => typeSet.has(p.name));
          }

          const display = filtered.slice(0, 20);
          searchCount.textContent = filtered.length + ' result' + (filtered.length !== 1 ? 's' : '');
          searchResults.style.display = display.length ? 'grid' : 'none';
          searchResults.innerHTML = display.map(p =>
            `<a href="/pokemon/${p.name}" class="card">` +
            `<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${p.id}.png" ` +
            `alt="${p.name}" loading="lazy" width="96" height="96" />` +
            `<div class="number">#${String(p.id).padStart(3, '0')}</div>` +
            `<div class="name">${p.name}</div></a>`
          ).join('');
        }

        searchInput.addEventListener('input', update);
        typeFilter.addEventListener('change', update);
      })();
    </script>
  </body>
</html>